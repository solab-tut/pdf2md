# Local LLM (Ollama) — point to your external Ollama instance
OLLAMA_URL=http://host.docker.external:11434
PDF2MD_MODEL=qwen2.5vl:32b

# Azure OpenAI (uncomment and fill to enable Azure models in the UI)
# AZURE_OPENAI_ENDPOINT=https://your-instance.openai.azure.com
# AZURE_OPENAI_API_KEY=your-key-here
# AZURE_OPENAI_DEPLOYMENTS=gpt-4o
# AZURE_OPENAI_API_VERSION=2024-10-21

# Common settings
PDF2MD_DEFAULT_DPI=150
PDF2MD_DEFAULT_THINKING=off
PDF2MD_MAX_IMAGE_EDGE=1800
PDF2MD_JPEG_QUALITY=75
PDF2MD_MAX_TOKENS=8192
PDF2MD_OLLAMA_KEEP_ALIVE=15m
PDF2MD_OLLAMA_TIMEOUT=600
PDF2MD_PAGE_ASSET_DPI=200
PDF2MD_PAGE_ASSET_JPEG_QUALITY=90
